<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chetna Naik | Data Analyst Portfolio</title>
  <meta name="description" content="Chetna Naik portfolio - Data Analyst skilled in Power BI, SQL, Python, Excel, Tableau, and dashboard development." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f172a;
      --panel: #111827;
      --panel-2: #0b1220;
      --text: #e5e7eb;
      --muted: #94a3b8;
      --line: rgba(148, 163, 184, 0.18);
      --accent: #60a5fa;
      --accent-2: #22c55e;
      --accent-3: #f59e0b;
      --white: #ffffff;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(96,165,250,0.18), transparent 28%),
        radial-gradient(circle at top right, rgba(34,197,94,0.12), transparent 24%),
        linear-gradient(180deg, #08111f 0%, #0f172a 55%, #0b1120 100%);
      color: var(--text);
    }

    a { color: inherit; text-decoration: none; }
    .container { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }
    .nav {
      position: sticky; top: 0; z-index: 30;
      backdrop-filter: blur(14px);
      background: rgba(8, 17, 31, 0.72);
      border-bottom: 1px solid var(--line);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 0;
      gap: 16px;
    }
    .brand { font-weight: 800; letter-spacing: 0.3px; }
    .brand span { color: var(--accent); }
    .nav-links { display: flex; flex-wrap: wrap; gap: 14px; color: var(--muted); font-size: 14px; }
    .nav-links a:hover { color: var(--text); }

    .hero {
      padding: 64px 0 24px;
      display: grid;
      grid-template-columns: 1.3fr 0.9fr;
      gap: 26px;
      align-items: center;
    }
    .badge {
      display: inline-flex; gap: 8px; align-items: center;
      padding: 8px 12px; border: 1px solid var(--line);
      background: rgba(255,255,255,0.03); border-radius: 999px;
      color: var(--muted); font-size: 13px;
    }
    h1 { font-size: clamp(36px, 5vw, 60px); line-height: 1.02; margin: 14px 0 14px; }
    .lead { font-size: 17px; line-height: 1.7; color: #cbd5e1; max-width: 62ch; }
    .actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      padding: 13px 18px; border-radius: 14px; font-weight: 600;
      border: 1px solid var(--line);
      transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }
    .btn:hover { transform: translateY(-2px); border-color: rgba(96,165,250,.6); }
    .btn.primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: white; }
    .btn.secondary { background: rgba(255,255,255,0.04); color: var(--text); }

    .hero-card {
      background: linear-gradient(180deg, rgba(17,24,39,0.95), rgba(11,18,32,0.92));
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 22px;
      box-shadow: 0 20px 50px rgba(0,0,0,.22);
    }
    .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .stat {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 16px;
    }
    .stat .num { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
    .stat .label { color: var(--muted); font-size: 13px; line-height: 1.45; }

    section { padding: 24px 0; }
    .section-title { font-size: 26px; margin: 0 0 10px; }
    .section-sub { color: var(--muted); margin: 0 0 18px; line-height: 1.7; }

    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .pill-grid { display: flex; flex-wrap: wrap; gap: 10px; }
    .pill {
      padding: 10px 14px; border-radius: 999px; border: 1px solid var(--line);
      background: rgba(255,255,255,0.03); color: #dbeafe; font-size: 14px;
    }

    .card {
      background: linear-gradient(180deg, rgba(17,24,39,0.95), rgba(11,18,32,0.92));
      border: 1px solid var(--line);
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 16px 36px rgba(0,0,0,.18);
    }
    .card-body { padding: 18px; }
    .card h3 { margin: 0 0 8px; font-size: 20px; }
    .meta { color: var(--muted); font-size: 14px; margin-bottom: 12px; }
    .card ul { margin: 0; padding-left: 18px; color: #dbeafe; line-height: 1.7; }
    .card ul li { margin-bottom: 6px; }
    .thumb {
      aspect-ratio: 16 / 9;
      width: 100%;
      object-fit: cover;
      display: block;
      background: #0b1220;
      border-bottom: 1px solid var(--line);
    }
    .placeholder {
      aspect-ratio: 16 / 9;
      display: grid; place-items: center;
      background:
        linear-gradient(135deg, rgba(96,165,250,.16), rgba(34,197,94,.12)),
        #0b1220;
      color: #bfdbfe;
      text-align: center;
      padding: 18px;
      font-weight: 600;
      border-bottom: 1px solid var(--line);
    }
    .footer {
      padding: 36px 0 60px;
      color: var(--muted);
      text-align: center;
      border-top: 1px solid var(--line);
      margin-top: 18px;
    }
    .small { font-size: 13px; line-height: 1.7; }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    .contact-box {
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 16px;
    }
    .contact-box a { color: #dbeafe; }

    @media (max-width: 900px) {
      .hero, .grid-3, .contact-grid { grid-template-columns: 1fr; }
      .stats { grid-template-columns: 1fr 1fr; }
      h1 { font-size: clamp(34px, 10vw, 50px); }
    }
    @media (max-width: 640px) {
      .container { width: min(100% - 20px, 1120px); }
      .nav-inner { flex-direction: column; align-items: flex-start; }
      .stats { grid-template-columns: 1fr; }
      .lead { font-size: 16px; }
    }
  </style>
</head>
